    {
      "name": "Valor total NF",
      "scope": [
        "constant.numeric.value.nfe"
      ],
      "settings": {
        "foreground": "#00FF6A",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Tags XML",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#607D8B"
      }
    },
    {
      "name": "Atributos",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#B0BEC5"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string.quoted.double"
      ],
      "settings": {
        "foreground": "#90A4AE"
      }
    }
