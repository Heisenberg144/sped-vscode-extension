{
  "name": "sped-fiscal-tools",
  "displayName": "Sped Fiscal Tools",
  "description": "Professional syntax highlighting and visual tools for SPED Fiscal files (.txt) and fiscal XML documents (NF-e, NFC-e, CT-e, NFS-e). Includes block detection, record highlighting, CNPJ/CPF, tax fields and custom dark themes.",
  "version": "1.1.0",
  "publisher": "adriangcirino",
  "license": "LICENSE",
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sped",
    "onLanguage:nfe"
  ],
  "scripts": {
    "compile": "tsc -p ./"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "sped",
    "sped fiscal",
    "nfe",
    "nf-e",
    "nfc-e",
    "cte",
    "ct-e",
    "nfse",
    "nfs-e",
    "xml fiscal",
    "danfe",
    "icms",
    "ipi",
    "pis",
    "cofins"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Heisenberg144/sped-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/Heisenberg144/sped-vscode-extension/issues"
  },
  "homepage": "https://github.com/Heisenberg144/sped-vscode-extension#readme",
  "contributes": {
    "commands": [
      {
        "command": "sped.toggleFields",
        "title": "Toggle SPED Field Documentation"
      }
    ],
    "configuration": {
      "title": "SPED Fiscal Tools",
      "properties": {
        "sped.fieldsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable SPED field hover documentation."
        }
      }
    },
    "languages": [
      {
        "id": "sped",
        "aliases": ["SPED", "SPED Fiscal"],
        "extensions": [".txt", ".sped", ".dec"],
        "firstLine": "^\\|0000\\|",
        "configuration": "./language-configuration.json"
      },
      {
        "id": "nfe",
        "aliases": ["NF-e", "NFC-e", "CT-e", "NFS-e", "XML Fiscal"],
        "extensions": [".xml"],
        "firstLine": "^<\\?xml",
        "mimetypes": ["application/xml", "text/xml"]
      }
    ],
    "grammars": [
      {
        "language": "sped",
        "scopeName": "source.sped",
        "path": "./syntaxes/sped.tmLanguage.json"
      },
      {
        "language": "nfe",
        "scopeName": "source.nfe",
        "path": "./syntaxes/nfe.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "SPED Fiscal Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sped-color-theme.json"
      },
      {
        "label": "NF-e Fiscal Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/nfe-dark-color-theme.json"
      }
    ]
  }
}
