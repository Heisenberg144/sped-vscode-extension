{
  "name": "sped-fiscal-tools",
  "displayName": "Sped Fiscal Tools",
  "description": "Professional syntax highlighting and visual tools for SPED Fiscal files (.txt). Includes block detection, record highlighting, CNPJ/CPF, ICMS fields and custom dark theme.",
  "version": "1.0.0",
  "publisher": "adriangcirino",
  "license": "LICENSE",
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sped"
  ],
  "scripts": {
    "compile": "tsc -p ./"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "sped",
    "sped fiscal"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Heisenberg144/sped-vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/Heisenberg144/sped-vscode-extension/issues"
  },
  "homepage": "https://github.com/Heisenberg144/sped-vscode-extension#readme",
  "contributes": {
    "commands": [
    {
      "command": "sped.toggleFields",
      "title": "Toggle SPED Field Documentation"
    }
  ],
    "configuration": {
      "title": "SPED Fiscal Tools",
      "properties": {
        "sped.fieldsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable SPED field hover documentation."
        }
      }
    },
    "languages": [
      {
        "id": "sped",
        "aliases": [
          "SPED",
          "SPED Fiscal"
        ],
        "extensions": [
          ".txt",
          ".sped",
          ".dec"
        ],
        "firstLine": "^\\|0000\\|",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sped",
        "scopeName": "source.sped",
        "path": "./syntaxes/sped.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "SPED Fiscal Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/sped-color-theme.json"
      }
    ]
  }
}
