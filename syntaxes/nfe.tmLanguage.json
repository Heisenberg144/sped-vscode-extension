          "match": "<(vNF|vProd|vNFe|vCarga|vTPrest|vRec|ValorServicos|ValorLiquidoNfse|ValorPis|ValorCofins)>([^<]*)</(vNF|vProd|vNFe|vCarga|vTPrest|vRec|ValorServicos|ValorLiquidoNfse|ValorPis|ValorCofins)>",
