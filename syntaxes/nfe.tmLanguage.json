{
  "name": "NF-e / NFC-e / CT-e / NFS-e XML",
  "scopeName": "source.nfe",
  "fileTypes": [],
  "patterns": [
    { "include": "#xmlDeclaration" },
    { "include": "#nfeProc" },
    { "include": "#infNFe" },
    { "include": "#identification" },
    { "include": "#emitDest" },
    { "include": "#det" },
    { "include": "#impostoBlock" },
    { "include": "#icmsBlock" },
    { "include": "#ipiBlock" },
    { "include": "#pisBlock" },
    { "include": "#cofinsBlock" },
    { "include": "#totalBlock" },
    { "include": "#transporteBlock" },
    { "include": "#cobBlock" },
    { "include": "#infAdic" },
    { "include": "#protNFe" },
    { "include": "#nfseBlock" },
    { "include": "#cteBlock" },
    { "include": "#chaveAcesso" },
    { "include": "#cnpjCpf" },
    { "include": "#dates" },
    { "include": "#financialValues" },
    { "include": "#cfopCst" },
    { "include": "#genericTag" },
    { "include": "#xmlComment" },
    { "include": "#xmlAttribute" }
  ],
  "repository": {

    "xmlDeclaration": {
      "match": "<\\?xml[^?]*\\?>",
      "name": "meta.xml-declaration.nfe",
      "captures": {
        "0": { "name": "comment.block.xml.nfe" }
      }
    },

    "xmlComment": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.nfe"
    },

    "xmlAttribute": {
      "match": "\\b(xmlns(?::[\\w]+)?|versao|Id|idLote)\\s*=\\s*\"([^\"]*)\"",
      "captures": {
        "1": { "name": "entity.other.attribute-name.nfe" },
        "2": { "name": "string.quoted.double.nfe" }
      }
    },

    "nfeProc": {
      "match": "</?(?:nfeProc|NFe|cteProc|CTe|compNfse|NfseCabecMsg|NfseMsg)\\b[^>]*>",
      "name": "entity.name.block.root.nfe"
    },

    "infNFe": {
      "match": "</?(?:infNFe|infCte|InfNfse|infNFeSupl)\\b[^>]*>",
      "name": "entity.name.block.inf.nfe"
    },

    "identification": {
      "patterns": [
        {
          "match": "</?(?:ide|infMunFG|IdentificacaoNfse|IdentificacaoRps)\\b[^>]*>",
          "name": "entity.name.block.ide.nfe"
        },
        {
          "match": "<(mod)>([^<]*)</(mod)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "support.type.modelo.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(serie)>([^<]*)</(serie)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "support.type.serie.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(nNF|nCT|numero|NumeroRps|nRPS)>([^<]*)</(nNF|nCT|numero|NumeroRps|nRPS)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "constant.numeric.numero.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(tpNF|tpCTe|tpAmb|tpEmis|tpImp|finNFe|indFinal|indPres|procEmi)>([^<]*)</(tpNF|tpCTe|tpAmb|tpEmis|tpImp|finNFe|indFinal|indPres|procEmi)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "constant.tipo_perfil.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(cMunFG|cMuf|cMun|cUF|CMUN)>([^<]*)</(cMunFG|cMuf|cMun|cUF|CMUN)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "entity.name.item.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(xMun|xUF|UF|cPais|xPais|xLgr|xBairro|nro|xCpl|CEP|fone)>([^<]*)</(xMun|xUF|UF|cPais|xPais|xLgr|xBairro|nro|xCpl|CEP|fone)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "entity.name.item.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        }
      ]
    },

    "chaveAcesso": {
      "patterns": [
        {
          "match": "<(chNFe|chCTe|chave|chAcesso)>([0-9]{44})</(chNFe|chCTe|chave|chAcesso)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "entity.name.chave.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "Id=\"(NFe[0-9]{44})\"",
          "captures": {
            "1": { "name": "entity.name.chave.nfe" }
          }
        }
      ]
    },

    "cnpjCpf": {
      "patterns": [
        {
          "match": "<(CNPJ|CNPJ_EMIT|CNPJ_TOM)>([0-9]{14})</(CNPJ|CNPJ_EMIT|CNPJ_TOM)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "entity.name.cnpj.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(CPF)>([0-9]{11})</(CPF)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "entity.name.cpf.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        },
        {
          "match": "<(IE|IEST|CRT)>([^<]*)</(IE|IEST|CRT)>",
          "captures": {
            "1": { "name": "support.type.tag.nfe" },
            "2": { "name": "constant.numeric.ie.nfe" },
            "3": { "name": "support.type.tag.nfe" }
          }
        }
      ]
    },

    "emitDest": {
      "patterns": [
        {
          "match": "</?(?:emit|dest|retirada|entrega|tomador|prestador|RpsSubstituido)\\b[^>]*>",
          "name": "entity.name.block.emitdest.nfe"
        },
        {
          "match": "<(xNome|xFant|IM|indIEDest)>([^<]*)</(xNome|xFant|IM|indIEDest)>",
