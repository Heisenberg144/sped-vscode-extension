          "match": "<(vDesc|vOutro|vFrete|vSeg|vOutros|vTotTrib|vTroco|vBCST|vST|vFCPST|vFCP)>([^<]*)</(vDesc|vOutro|vFrete|vSeg|vOutros|vTotTrib|vTroco|vBCST|vST|vFCPST|vFCP)>",
