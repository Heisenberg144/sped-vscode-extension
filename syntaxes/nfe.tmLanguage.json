          "name": "entity.name.block.det.nfe"
        },
        {
          "match": "</?prod\\b[^>]*>",
          "name": "entity.name.block.prod.nfe"
        },
        {
          "match": "<(cProd|cEAN|cEANTrib|cBarras)>([^<]*)</(cProd|cEAN|cEANTrib|cBarras)>",
